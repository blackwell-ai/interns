# Phase 2 processor — copy to .env (or just `export` these) before running processor.py
# Your OpenAI API key. The processor reads it from the environment; it is never
# written to the database or logged.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the model (default is gpt-5.5). Set to whatever your key can access.
# OPENAI_MODEL=gpt-5.5
