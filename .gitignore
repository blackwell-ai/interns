# run folders are per-execution artifacts — never committed (spec §4)
runs/

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/

# macOS
.DS_Store

# supabase local dev
supabase/.temp/
supabase/.branches/

# Local credentials — never committed (secrets distributed out-of-band)
credentials/.env

# Outreach run scratch (lead emails / send logs stay local).
# The *.csv rule only catches the top folder, so name the per-campaign
# subfolders and the enrichment cache explicitly. Lead emails never get pushed.
skills/autonomous-outreach/*.csv
skills/autonomous-outreach/agentic-ads/
skills/autonomous-outreach/taste-data/
skills/autonomous-outreach/enrichment_cache.jsonl
# campaign skill: live enriched-contact CSVs (lead emails / PII) stay local.
skills/campaign/enriched/
/tmp/
!skills/autonomous-outreach/lead_bank.csv
.gstack/

# Locally-installed plugin skills (origami, etc.) — not repo content
.claude/skills/

# Local artifacts and PII — never committed.
scratch/
logs.*.log
*-emails-*.csv
ai-researcher-emails-*.csv
agents/geo/good-molecules/proposals.zip

# tryblackwell.com website / platform front end — its own git repo, nested here.
/website/

# blackwell-benchmark — its own git repo, nested here.
/blackwell-benchmark/
