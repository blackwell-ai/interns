# Template for credentials/.env (which is gitignored — get real values from a
# teammate out-of-band, never via git). See credentials/README.md.

# --- Outreach agent ---
# Apollo/StoreLeads removed 2026-06-10 — Clay is the lead workbench
CLAY_API_KEY=              # Clay HTTP API, for headless harness flows
# gogcli / Google Workspace (transitional until harness M2):
GOG_ACCOUNT=               # default send account (Dartmouth)
GOG_KEYRING_PASSWORD=      # unlocks gog keyring in headless shells

# --- campaign skill (cold outreach) ---
# Provider that finds + verifies the decision-maker email per domain. Set the
# one you pass as --provider. campaign defaults to hunter; apollo is the
# alternative (only emails Apollo marks verified clear the default --min-score).
TOOLBOX_TOKEN_HUNTER=      # hunter.io API key (default provider)
TOOLBOX_TOKEN_APOLLO=      # apollo.io API key, from apollo.io > Settings > API
TOOLBOX_TOKEN_STORELEADS=  # storeleads.app key (Account > API) — optional, real-store domain sourcing

# --- Researcher agent ---
DISCORD_TOKEN=             # read-only monitoring account
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Supabase (harness backbone) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=       # server-side only — never ship to a client

# --- General ---
GITHUB_TOKEN=              # org-scoped PAT for agent git operations
# ANTHROPIC_API_KEY not needed — harness LLM calls run through headless
# Claude Code on the subscription (brain/decisions/2026-06-10-llm-via-claude-code.md)
